<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cuevas.powerspike.ui.MainController" fitToWidth="true" styleClass="scroll-pane">
    <VBox spacing="15" style="-fx-padding: 20;">
        
        <!-- Header -->
        <HBox spacing="5">
            <Label text="Power" styleClass="header-text" />
            <Label text="Spike" styleClass="header-accent" />
        </HBox>
        <Label text="League of Legends companion tool" styleClass="subtitle-text" />

        <!-- Search Bar -->
        <HBox styleClass="search-bar">
            <TextField fx:id="gameNameField" promptText="Nombre (ej: gh0s7face)" maxWidth="Infinity" />
            <TextField fx:id="tagLineField" promptText="Tag (ej: 314)" prefWidth="80" />
            <Button fx:id="searchButton" text="Buscar" styleClass="btn-search" />
        </HBox>

        <!-- Summoner Info Card -->
        <VBox fx:id="summonerCard" styleClass="section-card" managed="false" visible="false">
            <Label text="INVOCADOR" styleClass="section-title" />
            <HBox spacing="15">
                <ImageView fx:id="profileIcon" styleClass="profile-icon" />
                <VBox spacing="5">
                    <Label fx:id="summonerNameLabel" text="" styleClass="info-label" />
                    <Label fx:id="summonerLevelLabel" text="" styleClass="info-value" />
                    <Label fx:id="summonerPuuidLabel" text="" styleClass="subtitle-text" />
                </VBox>
            </HBox>
        </VBox>

        <!-- Live Game Button -->
        <Button fx:id="liveGameButton" text="Ver partida activa" styleClass="btn-live" managed="false" visible="false" />

        <!-- Live Game Error -->
        <Label fx:id="liveGameErrorLabel" text="" styleClass="error-text" />

        <!-- Teams Section -->
        <HBox fx:id="teamsContainer" spacing="15" managed="false" visible="false">
            
            <!-- Team Blue -->
            <VBox fx:id="blueTeamPanel" styleClass="team-panel team-blue" HBox.hgrow="ALWAYS" spacing="8">
                <Label text="EQUIPO AZUL" styleClass="section-title" />
            </VBox>

            <!-- Team Red -->
            <VBox fx:id="redTeamPanel" styleClass="team-panel team-red" HBox.hgrow="ALWAYS" spacing="8">
                <Label text="EQUIPO ROJO" styleClass="section-title" />
            </VBox>

        </HBox>

    </VBox>
</ScrollPane>
